};*/
Ok(())
}


pub fn run(&self,addr:&str)->Result<(),Error>{
let listener = TcpListener::bind(addr)?;
println!("Running on address {addr}!");
for stream in listener.incoming(){
self.handle_connections(stream?)?;
}
Ok(())

}






